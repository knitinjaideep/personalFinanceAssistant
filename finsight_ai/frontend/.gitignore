# ==============================================================================
# Coral Frontend — React / TypeScript / Vite .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ------------------------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
.output/

# ------------------------------------------------------------------------------
# Vite
# ------------------------------------------------------------------------------
.vite/
vite.config.*.timestamp-*
*.local

# ------------------------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
cypress/videos/
cypress/screenshots/
cypress/downloads/

# ------------------------------------------------------------------------------
# Environment & secrets  ⚠️  NEVER COMMIT THESE
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.test

# ------------------------------------------------------------------------------
# Package manager lock files (keep one, ignore others)
# If using npm: keep package-lock.json, ignore yarn.lock / pnpm-lock.yaml
# ------------------------------------------------------------------------------
yarn.lock
pnpm-lock.yaml
.pnpm-store/

# ------------------------------------------------------------------------------
# Cache directories
# ------------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache

# ------------------------------------------------------------------------------
# Storybook (if added later)
# ------------------------------------------------------------------------------
storybook-static/
.storybook/node_modules/

# ------------------------------------------------------------------------------
# Tailwind / PostCSS generated (never sources)
# ------------------------------------------------------------------------------
# (sources are committed; generated output is in dist/)

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ------------------------------------------------------------------------------
# Linux
# ------------------------------------------------------------------------------
*~

# ------------------------------------------------------------------------------
# Windows
# ------------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# IDEs & editors
# ------------------------------------------------------------------------------

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains / WebStorm
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo

# Emacs
\#*\#
.\#*

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej

# ------------------------------------------------------------------------------
# Vercel / Netlify / deployment artefacts (not used but good practice)
# ------------------------------------------------------------------------------
.vercel
.netlify

# ------------------------------------------------------------------------------
# Bundle analysis
# ------------------------------------------------------------------------------
bundle-stats.html
stats.json
