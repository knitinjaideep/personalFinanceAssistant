# ==============================================================================
# Coral Backend — Python / FastAPI .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Python bytecode & caches
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*$py.class

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ------------------------------------------------------------------------------
# Distribution / packaging
# ------------------------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/

# ------------------------------------------------------------------------------
# Installers
# ------------------------------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
.pytest_cache/
.cache/
.tox/
nosetests.xml
test-results/
test-reports/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover

# ------------------------------------------------------------------------------
# Type checking
# ------------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ------------------------------------------------------------------------------
# Linting / formatting
# ------------------------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------------------------
# Environment & secrets  ⚠️  NEVER COMMIT THESE
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
credentials/

# ------------------------------------------------------------------------------
# SQLite databases  ⚠️  Financial data — never commit
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ------------------------------------------------------------------------------
# Local data directories  ⚠️  Financial data — never commit
# ------------------------------------------------------------------------------
data/db/*
data/uploads/*
data/chroma/*
data/investments/morgan_stanley/*
data/investments/etrade/*
data/banking/chase/checking/*
data/banking/chase/credit_cards/*
data/banking/amex/*
data/banking/discover/*

# Keep folder structure
!data/db/.gitkeep
!data/uploads/.gitkeep
!data/chroma/.gitkeep
!data/investments/morgan_stanley/.gitkeep
!data/investments/etrade/.gitkeep
!data/banking/chase/checking/.gitkeep
!data/banking/chase/credit_cards/.gitkeep
!data/banking/amex/.gitkeep
!data/banking/discover/.gitkeep

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
*.log.*
logs/
log/

# ------------------------------------------------------------------------------
# Profiling
# ------------------------------------------------------------------------------
*.prof
*.lprof

# ------------------------------------------------------------------------------
# Jupyter (if ever used for exploration)
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ------------------------------------------------------------------------------
# Linux
# ------------------------------------------------------------------------------
*~

# ------------------------------------------------------------------------------
# Windows
# ------------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------------------------
# IDEs & editors
# ------------------------------------------------------------------------------

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains / PyCharm
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
\#*\#
.\#*

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej

# ------------------------------------------------------------------------------
# Ollama / model cache (heavy, local-only)
# ------------------------------------------------------------------------------
ollama_models/
ollama_cache/
model_cache/
