# Coral Environment Configuration
# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults are production-safe.

# ── App ─────────────────────────────────────────────────────────────────────
CORAL_ENVIRONMENT=development
CORAL_DEBUG=true
CORAL_LOG_LEVEL=INFO
CORAL_CORS_ORIGINS=["http://localhost:3000"]

# ── Ollama ───────────────────────────────────────────────────────────────────
CORAL_OLLAMA_BASE_URL=http://localhost:11434
CORAL_OLLAMA_CLASSIFICATION_MODEL=qwen3:8b
CORAL_OLLAMA_EXTRACTION_MODEL=qwen3:8b
CORAL_OLLAMA_ANALYSIS_MODEL=qwen3:8b
CORAL_OLLAMA_CHAT_MODEL=qwen3:8b
CORAL_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CORAL_OLLAMA_TEMPERATURE=0.1
CORAL_OLLAMA_NUM_CTX=8192
CORAL_OLLAMA_TIMEOUT_SECONDS=120

# ── Database ─────────────────────────────────────────────────────────────────
CORAL_DB_PATH=data/db/finsight.db
CORAL_DB_ECHO_SQL=false

# ── Chroma ───────────────────────────────────────────────────────────────────
CORAL_CHROMA_PERSIST_DIRECTORY=data/chroma
CORAL_CHROMA_COLLECTION_NAME=coral_statements
CORAL_CHROMA_RETRIEVAL_TOP_K=6

# ── Storage ──────────────────────────────────────────────────────────────────
CORAL_STORAGE_UPLOADS_DIRECTORY=data/uploads
CORAL_STORAGE_MAX_FILE_SIZE_MB=50
